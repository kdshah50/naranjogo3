# ── Tianguis ML Service — Environment Variables Reference ────────────────────
# This file is safe to commit to git. It documents every env var the service
# uses. Copy it to .env and fill in real values for local development.

# ── Service identity ──────────────────────────────────────────────────────────
SERVICE_NAME=tianguis-ml-service
ENV=development

# ── Google Vision API ─────────────────────────────────────────────────────────
# Get your key at https://console.cloud.google.com/apis/credentials
# Leave blank to use stub categorization results (safe for local dev)
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here

# ── Redis (ML result cache) ───────────────────────────────────────────────────
# Local dev: start Redis with `docker run -p 6379:6379 redis:7-alpine`
# Production: use your Upstash Redis URL
REDIS_URL=redis://localhost:6379/0
ML_CACHE_TTL_SECONDS=3600

# ── JWT / Auth ────────────────────────────────────────────────────────────────
# URL of the Auth Service JWKS endpoint (for verifying RS256 JWTs)
AUTH_SERVICE_JWKS_URL=http://auth-service/.well-known/jwks.json
# Shared secret for internal service-to-service calls (no JWT needed)
INTERNAL_API_SECRET=change-me-to-a-long-random-string

# ── Price model (XGBoost) ─────────────────────────────────────────────────────
# Path to the trained .joblib model file
# If the file doesn't exist, the service falls back to category median prices
PRICE_MODEL_PATH=app/models/price_model.joblib
PRICE_MODEL_MIN_COMPARABLES=5

# ── Listings Service ──────────────────────────────────────────────────────────
# Base URL of the Listings Service (used for internal webhook calls)
LISTINGS_SERVICE_URL=http://listings-service

# ── Fraud detection thresholds ────────────────────────────────────────────────
# Price below this fraction of the category median triggers a fraud flag
FRAUD_PRICE_FLOOR_PCT=0.20
# Image similarity above this threshold (pHash cosine) triggers a fraud queue
FRAUD_DESCRIPTION_SIM_THRESHOLD=0.90

# ── Vision confidence ─────────────────────────────────────────────────────────
# Labels below this confidence score fall back to category 'other'
VISION_CONFIDENCE_THRESHOLD=0.75
